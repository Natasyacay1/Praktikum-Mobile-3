<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:contentDescription="Beranda" />

        </LinearLayout>

        <!-- Reels -->
        <LinearLayout
            android:id="@+id/navReels"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_media_play"
                android:contentDescription="Reels" />

        </LinearLayout>

        <!-- Direct -->
        <LinearLayout
            android:id="@+id/navDirect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_send"
                android:contentDescription="Direct" />

        </LinearLayout>

        <!-- Search -->
        <LinearLayout
            android:id="@+id/navSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="Cari" />

        </LinearLayout>

        <!-- Profil (aktif - foto bulat) -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:scaleType="centerCrop"
                android:src="@drawable/fotoprofile"/>

        </LinearLayout>
    </LinearLayout>

<!--    scrollContent-->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavBar"
        android:background="#FFFFFF"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!--Header-->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <ImageView
                    android:id="@+id/btnAdd"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_input_add"
                    android:contentDescription="Tambah" />

                <LinearLayout
                    android:id="@+id/layoutUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="4dp"
                        android:src="@android:drawable/ic_lock_lock"
                        android:contentDescription="Akun Privat" />

                    <TextView
                        android:id="@+id/txtUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="asdfghijkkkk"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:src="@android:drawable/arrow_down_float"
                        android:contentDescription="Ganti akun" />

                </LinearLayout>

                <!-- Kanan: ikon notif + menu -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- Badge notif -->
                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp">

                        <ImageView
                            android:id="@+id/btnNotif"
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:src="@android:drawable/ic_dialog_alert"
                            android:contentDescription="Notifikasi" />

                        <TextView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="top|end"
                            android:background="#FF3B30"
                            android:gravity="center"
                            android:text="9+"
                            android:textColor="#FFFFFF"
                            android:textSize="8sp"
                            android:textStyle="bold" />

                    </FrameLayout>

                    <ImageView
                        android:id="@+id/btnMenu"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:contentDescription="Menu" />

                </LinearLayout>
            </RelativeLayout>

        <!-- profile, nama, stat juga dsini-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/circle_bg"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:src="@drawable/fotoprofile"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:background="#0095F6"
                        android:src="@android:drawable/ic_input_add"/>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/txtDisplayName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="nac"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#000000" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="she/her"
                            android:textSize="13sp"
                            android:textColor="#555555" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Postingan -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtPostCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#000000" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="postingan"
                                android:textSize="12sp"
                                android:textColor="#555555" />

                        </LinearLayout>

                        <!-- Pengikut -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtFollowerCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="173"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#000000" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="pengikut"
                                android:textSize="12sp"
                                android:textColor="#555555" />

                        </LinearLayout>

                        <!-- Mengikuti -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/txtFollowingCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="877"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#000000" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="mengikuti"
                                android:textSize="12sp"
                                android:textColor="#555555" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

<!--BIO-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/txtBio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="diam seperti limbad, other people know what #prinsip"
                    android:textSize="13sp"
                    android:textColor="#000000" />

                <TextView
                    android:id="@+id/txtLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="🔗 pin.it/1DOaYCktX"
                    android:textSize="13sp"
                    android:textColor="#006CFF"
                    android:textStyle="bold" />

                <!-- Musik -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_media_play"
                        android:contentDescription="Musik" />

                    <TextView
                        android:id="@+id/txtMusic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="The Only Exception • Paramore"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp">

                <Button
                    android:id="@+id/btnEditProfile"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@android:drawable/btn_default"
                    android:onClick="openEditProfile"
                    android:text="Edit profil"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnShareProfile"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:background="@android:drawable/btn_default"
                    android:text="Bagikan profil"
                    android:textColor="#000000"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnSuggestPeople"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:layout_marginStart="4dp"
                    android:background="@android:drawable/btn_default"
                    android:contentDescription="Saran orang"
                    android:src="@android:drawable/ic_menu_add" />

            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="14dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Highlight: Baru (lingkaran + ikon +) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginEnd="18dp"
                        android:orientation="vertical">

                        <FrameLayout
                            android:layout_width="68dp"
                            android:layout_height="68dp">

                            <ImageView
                                android:layout_width="68dp"
                                android:layout_height="68dp"
                                android:background="@drawable/circle_bg"
                                android:contentDescription="Baru" />

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_input_add"
                                android:contentDescription="Tambah highlight" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="68dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="Baru"
                            android:textColor="#000000"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Highlight 1: SHE -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginEnd="18dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/circle_bg"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foto1"/>
                        <TextView
                            android:layout_width="68dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="she"
                            android:textColor="#000000"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Highlight 2: 11 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginEnd="18dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/circle_bg"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foto2"/>

                        <TextView
                            android:layout_width="68dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="11"
                            android:textColor="#000000"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Highlight 3: ngampus -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginEnd="18dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/circle_bg"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foto3"/>

                        <TextView
                            android:layout_width="68dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="ngampus"
                            android:textColor="#000000"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- Highlight 4: m... -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginEnd="4dp"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/circle_bg"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/foto4"/>

                        <TextView
                            android:layout_width="68dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:gravity="center"
                            android:text="m..."
                            android:textColor="#000000"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal">

                <!-- Tab Grid (aktif) -->
                <LinearLayout
                    android:id="@+id/tabGrid"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:contentDescription="Tab Grid" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="8dp"
                        android:background="#000000" />

                </LinearLayout>

                <!-- Tab Reels -->
                <LinearLayout
                    android:id="@+id/tabReels"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_media_play"
                        android:contentDescription="Tab Reels" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent" />

                </LinearLayout>

                <!-- Tab Collab / Repost -->
                <LinearLayout
                    android:id="@+id/tabCollab"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_rotate"
                        android:contentDescription="Tab Collab" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent" />

                </LinearLayout>

                <!-- Tab Ditandai -->
                <LinearLayout
                    android:id="@+id/tabTagged"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:contentDescription="Tab Ditandai" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1.5dp"
                        android:layout_marginTop="8dp"
                        android:background="@android:color/transparent" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider bawah tab -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#DDDDDD" />

            <!-- Baris 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgPost1"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="1.5dp"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:scaleType="centerCrop"
                    android:src="@drawable/post1"/>

                <ImageView
                    android:id="@+id/imgPost2"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="1.5dp"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:scaleType="centerCrop"
                    android:src="@drawable/post2"/>

                <ImageView
                    android:id="@+id/imgPost3"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_weight="1"
                    android:background="@android:drawable/dialog_holo_light_frame"
                    android:scaleType="centerCrop"
                    android:src="@drawable/post3"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1.5dp" />
            <View android:layout_width="match_parent" android:layout_height="1.5dp" />

            </LinearLayout>

    </ScrollView>

</RelativeLayout>