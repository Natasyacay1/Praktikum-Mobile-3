<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="24dp">

    <!-- Bahasa Indonesia bar (atas) -->
    <TextView
        android:id="@+id/tvBahasa"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"
        android:drawableEnd="@android:drawable/arrow_down_float"
        android:text="Bahasa Indonesia"
        android:textColor="#FFFFFF"
        android:textSize="13sp" />

    <!-- Logo Instagram -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_below="@id/tvBahasa"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="48dp"
        android:src="@drawable/ig_logo_gradient"
        android:contentDescription="Instagram Logo" />

    <!-- Form area -->
    <LinearLayout
        android:id="@+id/layoutForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/ivLogo"
        android:layout_marginTop="48dp"
        android:orientation="vertical">

        <!-- NIM Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:boxBackgroundColor="#1A1A1A"
            app:boxStrokeColor="#363636"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="#A8A8A8"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNim"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nama pengguna, email, atau nomor ponsel"
                android:textColor="#FFFFFF"
                android:textColorHint="#A8A8A8"
                android:textSize="14sp"
                android:backgroundTint="#1A1A1A"
                android:inputType="text"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Password Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:boxBackgroundColor="#1A1A1A"
            app:boxStrokeColor="#363636"
            app:boxStrokeWidth="1dp"
            app:hintTextColor="#A8A8A8"
            app:passwordToggleEnabled="true"
            app:passwordToggleTint="#A8A8A8"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Kata sandi"
                android:textColor="#FFFFFF"
                android:textColorHint="#A8A8A8"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:paddingTop="14dp"
                android:paddingBottom="14dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Tombol Login -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Login"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#0095F6"
            android:stateListAnimator="@null"
            app:cornerRadius="8dp" />

        <!-- Lupa Kata Sandi -->
        <TextView
            android:id="@+id/tvForgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="14dp"
            android:text="Lupa kata sandi?"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Tombol Buat Akun Baru (bawah) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#262626"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Buat akun baru"
            android:textColor="#0095F6"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#000000"
            android:stateListAnimator="@null"
            app:strokeColor="#363636"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- Meta Logo -->
        <TextView
            android:id="@+id/tvRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="14dp"
            android:text="∞  Meta"
            android:textColor="#A8A8A8"
            android:textSize="13sp" />

    </LinearLayout>

</RelativeLayout>
