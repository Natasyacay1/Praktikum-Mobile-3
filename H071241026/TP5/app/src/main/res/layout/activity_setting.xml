<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kembali" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pengaturan"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#262626" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

            <!-- Section: Akun -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AKUN"
                android:textColor="#A8A8A8"
                android:textSize="12sp"
                android:letterSpacing="0.08"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <!-- NIM Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="U"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@drawable/circle_purple"
                    android:layout_marginEnd="14dp" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profil saya"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp" />
                    <TextView
                        android:id="@+id/tvNimSetting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NIM: —"
                        android:textColor="#A8A8A8"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textColor="#A8A8A8" android:textSize="20sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#262626" />

            <!-- Section: Tampilan -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TAMPILAN"
                android:textColor="#A8A8A8"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <!-- Dark Mode Switch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🌙"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="#1A1A1A"
                    android:layout_marginEnd="14dp" />

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mode Gelap" android:textColor="#FFFFFF" android:textSize="15sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Simpan di SharedPreferences" android:textColor="#A8A8A8" android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchDarkMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="#FFFFFF"
                    app:trackTint="#0095F6" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#262626" />

            <!-- SharedPreferences Data Viewer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SHARED PREFERENCES — DATA TERSIMPAN"
                android:textColor="#A8A8A8"
                android:textSize="12sp"
                android:paddingStart="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvSharedPrefsData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:padding="14dp"
                android:background="#0D1F33"
                android:text=""
                android:textColor="#0095F6"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <!-- Logout -->
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#262626" />

            <TextView
                android:id="@+id/tvLogoutSetting"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="Keluar"
                android:textColor="#E53E3E"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackground" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
