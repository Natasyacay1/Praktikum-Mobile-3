<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Top Bar IG style -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#000000">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Instagram"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Notifikasi"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_dialog_email"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Pesan" />
    </LinearLayout>

    <View
        android:id="@+id/divTop"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_below="@id/topBar"
        android:background="#262626" />

    <!-- Konten tengah -->
    <LinearLayout
        android:id="@+id/layoutContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/divTop"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Avatar bulat -->
        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:text="U"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/circle_purple"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selamat datang 026"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Badge SharedPreferences -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  SharedPreferences aktif  "
            android:textColor="#0095F6"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/badge_blue"
            android:layout_marginBottom="36dp" />

        <!-- Tombol LOGOUT -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="LOGOUT"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#E53E3E"
            android:stateListAnimator="@null"
            android:layout_marginBottom="12dp"
            app:cornerRadius="8dp" />

        <!-- Tombol SETTING -->
        <Button
            android:id="@+id/btnSetting"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="SETTING"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#1A1A1A"
            android:stateListAnimator="@null"
            app:strokeColor="#363636"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#000000"
        android:gravity="center_vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#262626" />
    </LinearLayout>

</RelativeLayout>
